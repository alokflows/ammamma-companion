<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Talk companion: reach the AI (online only) and hear her voice. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Theft guard: silently photograph whoever handles the phone in Travel mode. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Foreground service keeps the companion alive on ColorOS, which kills
         ordinary background apps aggressively. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Ask to be exempt from battery optimization so we stay alive persistently. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Lets the dismiss card wake the screen so she never misses a warning. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- One-tap calling from a face button. -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- Announce WHO is calling (read incoming call state + number). -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- On Android 9+ the system hides the caller's NUMBER unless the app also
         holds READ_CALL_LOG — without it every caller becomes "unknown". Needed
         so the app works on the whole family's phones, not only Android 8.1. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <!-- Find-my-phone: react to a family SMS and buzz loudly. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Grandpa finder: text the phone's GPS location back to the family sender. -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Read the PHONE's own contact book so we can announce callers saved there,
         not only people added inside the app. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Restart the companion automatically after the phone reboots. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- ColorOS blocks background activity launches unless "display over other
         apps" is granted — needed so alert screens actually APPEAR. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The giant dismiss card. Its own task, shows over the lock screen,
             transparent to the launcher (no icon of its own). -->
        <activity
            android:name=".AlertActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:theme="@android:style/Theme.Material.NoActionBar.Fullscreen" />

        <!-- Live charging screen: percentage, health, time-to-full, spoken aloud. -->
        <activity
            android:name=".ChargingActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:theme="@android:style/Theme.Material.NoActionBar.Fullscreen" />

        <!-- stateHidden: the keyboard must NEVER pop up on its own — it buries the
             mic button and terrifies a non-typist. It opens only if the text box
             (the family's fallback) is deliberately tapped. -->
        <activity
            android:name=".TalkActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden|adjustResize" />

        <!-- The Talk companion's chat-session list (title + relative date, open/delete). -->
        <activity
            android:name=".ChatListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".FindPhoneActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:theme="@android:style/Theme.Material.NoActionBar.Fullscreen" />

        <!-- Announces who is calling when the phone rings. -->
        <receiver
            android:name=".CallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Listens for the family "find my phone" SMS. Protected so only the
             system telephony stack can deliver to it. -->
        <receiver
            android:name=".FindPhoneReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Brings the companion back after a reboot or an app update. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".CompanionService"
            android:exported="false" />

        <!-- Texts the phone's GPS location back when find-my-phone fires. -->
        <service
            android:name=".LocationReplyService"
            android:exported="false" />

    </application>
</manifest>
