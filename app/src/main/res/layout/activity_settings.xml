<?xml version="1.0" encoding="utf-8"?>
<!-- Family-only settings (not for grandma). Bilingual Telugu · English labels. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF3E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:focusableInTouchMode="true"><!-- steals initial focus so the keyboard doesn't auto-pop -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="సెట్టింగ్‌లు · Settings"
            android:textColor="#402A1C"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="కుటుంబం కోసం మాత్రమే"
            android:textColor="#8A7361"
            android:textSize="14sp" />

        <!-- ============ DEMOS: show the family every event on demand ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="డెమో · Demo"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Try every alert now — no need to wait for a real call or a flat battery."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <Button
            android:id="@+id/callerDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:paddingVertical="14dp"
            android:text="🔊 కాలర్ డెమో · Caller demo"
            android:textSize="16sp" />

        <Button
            android:id="@+id/lowBatteryDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="🪫 తక్కువ ఛార్జ్ డెమో · Low battery demo"
            android:textSize="16sp" />

        <Button
            android:id="@+id/fullBatteryDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="🔋 ఛార్జ్ నిండింది డెమో · Battery full demo"
            android:textSize="16sp" />

        <Button
            android:id="@+id/chargingDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="⚡ ఛార్జింగ్ తెర డెమో · Charging screen demo"
            android:textSize="16sp" />

        <Button
            android:id="@+id/findPhoneDemo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="📢 ఫోన్ వెతుకు డెమో · Find-phone demo"
            android:textSize="16sp" />

        <!-- ============ SOUNDS: volume, mute, per-category gates ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="శబ్దాలు · Sounds"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Control how loud the phone talks, and which things it speaks about."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <Switch
            android:id="@+id/muteSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="మాట్లాడొద్దు (మ్యూట్) · Mute all voice"
            android:textColor="#5A3720"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Safety lines (find-my-phone, urgent low battery) still speak even when muted."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="మాటల వాల్యూమ్ · Speech volume"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/volumeSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:min="10"
            android:max="100" />

        <TextView
            android:id="@+id/volumeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/greetingSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="ఇంటికి వచ్చినప్పుడు నమస్తే · Home greeting"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/uiSoundsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="బటన్ మాటలు · UI tap lines (e.g. the gear hint)"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/chargeSoundsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="ఛార్జింగ్ ప్రకటనలు · Charging announcements"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <!-- ============ PERMISSIONS (rows built in code) ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="అనుమతులు · Permissions"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Red items are missing — tap one to allow it."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <!-- Shown only when every permission is granted. -->
        <TextView
            android:id="@+id/permsAllGood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:text="అన్నీ ఉన్నాయి ✔ · All good"
            android:textColor="#1E8E3E"
            android:textSize="17sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/permsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <!-- ============ CALLER ANNOUNCEMENT ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="కాలర్ ప్రకటన · Caller announcement"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="When the phone rings, the name is spoken this often."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="ప్రతి N సెకన్లకు · Repeat every N seconds"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/callerSeconds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="4"
            android:inputType="number"
            android:textColor="#402A1C" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="ఎన్ని సార్లు · How many times"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 = once."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/callerTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="12"
            android:inputType="number"
            android:textColor="#402A1C" />

        <!-- ============ FIND-PHONE ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="ఫోన్ కనుక్కునే రహస్య పదం · Find-phone code word"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text this word to her phone and it will ring loudly, even on silent."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/codeWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="FINDME"
            android:inputType="text"
            android:textColor="#402A1C" />

        <!-- ============ FAMILY NUMBERS (dynamic rows, built in code) ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="కుటుంబ నంబర్లు · Family numbers"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Only these numbers can ring the phone with the code word. Leave empty to allow anyone (less safe)."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/numbersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/addNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="＋ నంబర్ జోడించండి · Add number"
            android:textSize="16sp" />

        <!-- ============ LOCATION SMS REPLY (applies immediately) ============ -->
        <Switch
            android:id="@+id/locationReplySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="లొకేషన్ SMS జవాబు · Location SMS reply"
            android:textColor="#5A3720"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="When family texts the code word, the phone also texts back where it is. Turn off to disable."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <!-- ============ BATTERY ALERT LEVELS ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="బ్యాటరీ హెచ్చరికలు · Battery alerts"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="తక్కువ ఛార్జ్ స్థాయి (%) · Low battery level"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Below this %, she hears 'please charge' and sees the red card."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/battLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="20"
            android:inputType="number"
            android:textColor="#402A1C" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="అత్యవసర స్థాయి (%) · Urgent level"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A second, urgent warning. Always at or below the low level."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/battCritical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="10"
            android:inputType="number"
            android:textColor="#402A1C" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="గుర్తు చేసే విరామం (నిమిషాలు) · Remind every N minutes"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How often it repeats 'please charge' until the charger is in."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/batteryMinutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="5"
            android:inputType="number"
            android:textColor="#402A1C" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="ఛార్జ్ సరిపోయే స్థాయి (%) · Charged-enough level"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="While charging, announce 'enough — unplug' at this %. 100 = only when full."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/battCharged"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="100"
            android:inputType="number"
            android:textColor="#402A1C" />

        <!-- ============ AI ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="మాట్లాడు AI · Talk AI"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste one API key. The provider is detected from the key (gsk_… = Groq, sk-or-… = OpenRouter, sk-… = OpenAI) — no address to type. Tap 'Get models ▾' beside a key to pick 'Auto (best)' or a specific model. Add a second key as a free backup if the first gets busy. Stored only on this phone."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <!-- One row per API key, built in code (key + Get models ▾ + remove). -->
        <LinearLayout
            android:id="@+id/keysContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/addKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingVertical="12dp"
            android:text="＋ మరో API key జోడించండి · Add another API key" />

        <Button
            android:id="@+id/testAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Test AI · పరీక్ష" />

        <!-- ============ Travel mode ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="ప్రయాణం · Travel mode"
            android:textColor="#5A3720"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="When ON: every time the charger is plugged in or out, the phone silently sends its GPS location to the travel numbers below (or the family numbers above, if no travel numbers are set) AND quietly takes a front + back photo (saved on the phone only). The phone still speaks the normal charge line, so it looks ordinary. Turn on when she travels; needs SMS + location + camera permission, no internet."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <Switch
            android:id="@+id/travelSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="ప్రయాణ మోడ్ ఆన్ · Turn on travel mode"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <!-- Travel-mode recipients — a separate list from the family numbers above,
             so who gets breadcrumbs while she travels can differ from who can ring
             the phone with the code word. Same row pattern as family numbers. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ప్రయాణ నంబర్లు · Travel numbers"
            android:textColor="#5A3720"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Who gets the location breadcrumb. Leave empty to use the family numbers above instead."
            android:textColor="#8A7361"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/travelNumbersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/addTravelNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingVertical="14dp"
            android:text="＋ నంబర్ జోడించండి · Add travel number"
            android:textSize="16sp" />

        <!-- Channels: SMS is live today; email is a documented future relay
             (see TRAVEL_EMAIL.md) — shown disabled so the family knows it's
             planned, not broken. No WhatsApp channel — SMS/email only. -->
        <Switch
            android:id="@+id/travelSmsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="SMS ద్వారా పంపండి · Send by SMS"
            android:textColor="#402A1C"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/travelEmailSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:enabled="false"
            android:text="ఇమెయిల్ (త్వరలో) · Email (coming soon)"
            android:textColor="#B0A08E"
            android:textSize="15sp" />

        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:paddingVertical="16dp"
            android:text="సేవ్ · Save"
            android:textSize="20sp" />

    </LinearLayout>
</ScrollView>
