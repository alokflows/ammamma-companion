<?xml version="1.0" encoding="utf-8"?>
<!-- The Talk companion. Warm, dark, high-contrast — a scrollable chat transcript
     (her messages right, companion left), a big mic bar, and a typing bar below it
     as the fallback that always works. She can't read, so status changes are also
     always spoken (TalkActivity), never left silent on screen alone. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2A1A0F">

    <!-- Header: back, chat title, new-chat, chat list -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="✕"
            android:textColor="#FFF4E8"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/chatTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="మాట్లాడు"
            android:textColor="#FFF4E8"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/newChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="కొత్తది +"
            android:textColor="#FFF4E8"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/chatsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:padding="8dp"
            android:text="చాట్లు"
            android:textColor="#FFF4E8"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Chat transcript -->
    <ListView
        android:id="@+id/transcript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:transcriptMode="alwaysScroll"
        android:stackFromBottom="true"
        android:clipToPadding="false"
        android:paddingVertical="6dp" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:text="నొక్కి మాట్లాడండి లేదా టైప్ చేయండి"
        android:textColor="#D9C6B4"
        android:textSize="16sp" />

    <!-- Big tappable mic bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="12dp">

        <FrameLayout
            android:id="@+id/micButton"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/mic_circle">

            <ImageView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:contentDescription="@null" />
        </FrameLayout>
    </FrameLayout>

    <!-- Typing bar — always-works fallback -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingBottom="14dp">

        <EditText
            android:id="@+id/input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="ఇక్కడ టైప్ చేయండి"
            android:textColorHint="#9C8973"
            android:textColor="#FFF4E8"
            android:inputType="textShortMessage"
            android:imeOptions="actionSend" />

        <Button
            android:id="@+id/send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="పంపు"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
