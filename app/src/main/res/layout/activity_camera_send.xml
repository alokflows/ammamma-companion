<?xml version="1.0" encoding="utf-8"?>
<!-- Take-a-photo-and-send-it screen. The camera opens almost instantly over this
     (see CameraSendActivity.onCreate), so what actually shows for a while is the
     review screen below: full-bleed preview + three huge buttons. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <ImageView
        android:id="@+id/ivPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:background="#000000"
        android:contentDescription="@null" />

    <!-- Hidden until the camera returns a photo; see CameraSendActivity.showReview(). -->
    <LinearLayout
        android:id="@+id/reviewButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="96dp"
            android:paddingTop="22dp"
            android:paddingBottom="22dp"
            android:background="@drawable/btn_primary_green"
            android:stateListAnimator="@null"
            android:elevation="6dp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:text="వాట్సాప్‌లో పంపు"
            android:textSize="32sp" />

        <Button
            android:id="@+id/btnRetake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="72dp"
            android:background="@drawable/btn_outline"
            android:stateListAnimator="@null"
            android:textColor="@color/brown"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:text="మళ్ళీ తియ్యి"
            android:textSize="26sp" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="72dp"
            android:background="@drawable/btn_outline"
            android:stateListAnimator="@null"
            android:textColor="@color/brown"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:text="వద్దు"
            android:textSize="26sp" />

    </LinearLayout>
</LinearLayout>
