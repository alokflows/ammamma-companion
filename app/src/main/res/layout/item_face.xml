<?xml version="1.0" encoding="utf-8"?>
<!-- One face button in the photo-dial grid. Populated from a Contact in code.
     The whole card is tappable and places the call. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/card_lux"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="18dp"
    android:paddingBottom="16dp"
    android:elevation="0dp">

    <!-- avatar: a circle whose ring color is set per-person in code -->
    <FrameLayout
        android:id="@+id/avatarFrame"
        android:layout_width="84dp"
        android:layout_height="84dp">

        <!-- person icon by default; swapped in code for the family-set photo when one exists -->
        <ImageView
            android:id="@+id/avatarImage"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:contentDescription="@null" />

        <!-- small green "call" badge (hidden when no number is set yet) -->
        <ImageView
            android:id="@+id/callBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:src="@drawable/ic_call_badge"
            android:contentDescription="@null" />
    </FrameLayout>

    <TextView
        android:id="@+id/name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:includeFontPadding="true"
        android:textColor="@color/ink_text"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/rel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="true"
        android:textColor="@color/ink_text_dim"
        android:textSize="13sp" />

    <!-- Always-visible hint on cards with no number yet (not just a transient toast). -->
    <TextView
        android:id="@+id/noNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:includeFontPadding="true"
        android:text="నంబర్ లేదు"
        android:textColor="@color/ink_text_dim"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
