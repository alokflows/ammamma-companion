<?xml version="1.0" encoding="utf-8"?>
<!-- WP-LUX: a family-flag pill toggle in its OFF state — same ink-card family
     as card_lux.xml, just a small pill radius so it reads as a toggle chip. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_light">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ink_card" />
            <stroke android:width="1dp" android:color="@color/ink_card_stroke" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</ripple>
