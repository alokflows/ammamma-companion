<?xml version="1.0" encoding="utf-8"?>
<!-- WP-LUX luminous card: deep-ink fill, hairline lighter stroke, 28dp radius.
     Shared by Home's face cards and the centered Alert/Charging/FindPhone cards
     so all four redesigned screens read as one design language. New file — the
     older shared card_face.xml (also used by Recorder/Chat rows) is left alone. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ink_card" />
    <corners android:radius="28dp" />
    <stroke android:width="1dp" android:color="@color/ink_card_stroke" />
</shape>
