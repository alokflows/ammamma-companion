<?xml version="1.0" encoding="utf-8"?>
<!-- WP-LUX: weather pill on the ink Home backdrop — same luminous-card family as
     card_lux.xml, tighter radius since it's a small tile, not a big card. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ink_card" />
    <corners android:radius="20dp" />
    <stroke android:width="1dp" android:color="@color/ink_card_stroke" />
</shape>
